{
  "expo": {
    "name": "AsliLearn AI",
    "slug": "aslilearn-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/app-icon-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aslilearn.mobile",
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.aslilearn.mobile",
      "versionCode": 4,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "scheme": "aslilearn",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9fd6f1b6-ecfb-4ded-942b-3b2e8700d504"
      }
    },
    "owner": "sankaabhiram"
  }
}
