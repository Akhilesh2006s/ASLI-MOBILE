{
  "expo": {
    "name": "AsliLearn AI",
    "slug": "aslilearn-mobile",
    "version": "1.0.10",
    "orientation": "default",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/app-icon-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tech.aslilearnai",
      "buildNumber": "10"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tech.aslilearnai",
      "versionCode": 14,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "aslilearn",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f65847b9-62a4-4f35-ae9d-d7adaeac2c6a"
      }
    },
    "owner": "amenityforge"
  }
}
